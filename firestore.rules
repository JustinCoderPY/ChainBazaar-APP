rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═════════════���═════════════════════════════════════════════
    // PRODUCTS (listings)
    // ═══════════════════════════════════════════════════════════
    // Marketplace listings are publicly readable.
    // Only authenticated users can create listings.
    // Only the seller (creator) can update or delete their own listing.
    //
    // Collections: /products/{productId}
    // Used by: firebaseService.ts → getAllListings(), getUserListings(),
    //          createListing(), deleteListing()
    // ─────────────────────────────────────────────────────────
    match /products/{productId} {
      // Anyone can browse listings — including guests and
      // users whose auth state hasn't resolved yet.
      allow read: if true;

      // Only logged-in users can create a listing.
      // Validates that sellerId matches the authenticated user
      // so nobody can impersonate another seller.
      allow create: if request.auth != null
                    && request.resource.data.sellerId == request.auth.uid;

      // Only the seller who created the listing can update it.
      allow update: if request.auth != null
                    && resource.data.sellerId == request.auth.uid;

      // Only the seller who created the listing can delete it.
      allow delete: if request.auth != null
                    && resource.data.sellerId == request.auth.uid;
    }

    // ═══════════════════════════════════════════════════════════
    // USERS (profiles)
    // ═══════════════════════════════════════════════════════════
    // User profiles are publicly readable (needed for seller info,
    // participant names in messaging, etc.).
    // Only the user themselves can write their own profile document.
    //
    // Collections: /users/{userId}
    // Used by: AuthContext.tsx → signup() calls setDoc(doc(db, 'users', uid))
    // ─────────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone can read user profiles (name, avatar for display)
      allow read: if true;

      // Only the user themselves can create/update their profile
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // ═══════════════════════════════════════════════════════════
    // CONVERSATIONS
    // ═══════════════════════════════════════════════════════════
    // 1-to-1 messaging conversations between buyer and seller.
    // Only participants of a conversation can read or modify it.
    //
    // Collections: /conversations/{convId}
    // Used by: messageService.ts → getOrCreateConversation(),
    //          listenToConversations()
    // ─────────────────────────────────────────────────────────
    match /conversations/{convId} {
      function conversationPath() {
        return /databases/$(database)/documents/conversations/$(convId);
      }

      function conversationExists() {
        return exists(conversationPath());
      }

      function isConversationParticipant() {
        return request.auth != null
               && conversationExists()
               && request.auth.uid in get(conversationPath()).data.participants;
      }

      // Only participants can read conversation metadata
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;

      // Creating a conversation: the creator must be in the
      // participants array (can't create a chat you're not part of)
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;

      // Only participants can update (e.g., lastMessage, lastUpdated)
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants
                    && request.resource.data.participants == resource.data.participants;

      // Conversations cannot be deleted from the client
      allow delete: if false;

      // ─── Messages Subcollection ──────────────────────────
      // /conversations/{convId}/messages/{messageId}
      // Used by: messageService.ts → sendMessage(),
      //          listenToMessages(), markMessagesAsRead()
      // ───────────────────────────────────────────────────────
      match /messages/{messageId} {
        // Only conversation participants can read messages
        allow read: if isConversationParticipant();

        // Only participants can create messages, and senderId
        // must match the authenticated user (no spoofing)
        allow create: if request.auth != null
                      && request.resource.data.senderId == request.auth.uid
                      && isConversationParticipant();

        // Participants can update messages (for marking as read)
        allow update: if isConversationParticipant();

        // Messages cannot be deleted from the client
        allow delete: if false;
      }
    }

    // ═══════════════════════════════════════════════════════════
    // CATCH-ALL: DENY EVERYTHING ELSE
    // ═══════════════════════════════════════════════════════════
    // Any collection not explicitly matched above is denied.
    // This is Firestore's default behavior, but stating it
    // explicitly makes audits clearer.
    // ─────────────────────────────────────────────────────────
    // (No catch-all match needed — Firestore denies by default)
  }
}
